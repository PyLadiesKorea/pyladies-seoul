# PyLadies Seoul Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env files to version control

# =============================================================================
# DJANGO CORE SETTINGS
# =============================================================================

# Django Secret Key (REQUIRED)
# Generate with: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-super-secret-django-key-here-change-in-production

# Debug mode (NEVER set to True in production)
DEBUG=False

# Django Settings Module
DJANGO_SETTINGS_MODULE=config.settings.production

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=pyladiesseoul.org,www.pyladiesseoul.org

# Logfire APM (optional)
LOGFIRE_TOKEN=your-logfire-token-here

# =============================================================================
# SSL AND DOMAIN CONFIGURATION
# =============================================================================

# Domain names
DOMAIN_NAME=pyladiesseoul.org
WWW_DOMAIN_NAME=www.pyladiesseoul.org
BASE_URL=https://pyladiesseoul.org

# Let's Encrypt settings
CERTBOT_EMAIL=admin@pyladiesseoul.org

# =============================================================================
# ADMIN USER CONFIGURATION
# =============================================================================

# Django superuser (for automated creation)
DJANGO_SUPERUSER_EMAIL=admin@pyladiesseoul.org
DJANGO_SUPERUSER_PASSWORD=secure_admin_password_change_me

# =============================================================================
# DEPLOYMENT CONFIGURATION
# =============================================================================

# Data directory for volumes
DATA_DIR=./data

# Backup retention
BACKUP_RETENTION_DAYS=7
# Analytics (optional)
GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX
