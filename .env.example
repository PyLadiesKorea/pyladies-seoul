# PyLadies Seoul Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env files to version control

# =============================================================================
# DJANGO CORE SETTINGS
# =============================================================================

# Django Secret Key (REQUIRED)
# Generate with: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-super-secret-django-key-here-change-in-production

# Debug mode (NEVER set to True in production)
DEBUG=False

# Django Settings Module
DJANGO_SETTINGS_MODULE=config.settings.production

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=pyladiesseoul.org,www.pyladiesseoul.org

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL Database URL
DATABASE_URL=postgresql://username:password@hostname:5432/database_name

# Database credentials (alternative to DATABASE_URL)
POSTGRES_DB=pyladies_seoul
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secure_database_password_change_me

# Database connection pooling
USE_PGBOUNCER=False

# =============================================================================
# CACHE AND SESSION CONFIGURATION
# =============================================================================

# Redis URL for caching and sessions
REDIS_URL=redis://:password@hostname:6379/0

# Redis password
REDIS_PASSWORD=secure_redis_password_change_me

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================

# Email backend
EMAIL_BACKEND=django_anymail.backends.mailgun.EmailBackend

# SMTP settings
EMAIL_HOST=smtp.mailgun.org
EMAIL_PORT=587
EMAIL_HOST_USER=postmaster@mg.pyladiesseoul.org
EMAIL_HOST_PASSWORD=your-mailgun-smtp-password
EMAIL_USE_TLS=True

# Email addresses
DEFAULT_FROM_EMAIL=noreply@pyladiesseoul.org
ADMIN_EMAIL=admin@pyladiesseoul.org

# Mailgun API settings (if using Mailgun)
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_SENDER_DOMAIN=mg.pyladiesseoul.org

# =============================================================================
# FILE STORAGE (AWS S3)
# =============================================================================

# AWS S3 settings (optional - leave empty to use local storage)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_STORAGE_BUCKET_NAME=pyladies-seoul-media
AWS_S3_REGION_NAME=ap-northeast-2

# =============================================================================
# MONITORING AND LOGGING
# =============================================================================

# Sentry error tracking (optional)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=production

# Logfire APM (optional)
LOGFIRE_TOKEN=your-logfire-token-here

# =============================================================================
# SSL AND DOMAIN CONFIGURATION
# =============================================================================

# Domain names
DOMAIN_NAME=pyladiesseoul.org
WWW_DOMAIN_NAME=www.pyladiesseoul.org
BASE_URL=https://pyladiesseoul.org

# Let's Encrypt settings
CERTBOT_EMAIL=admin@pyladiesseoul.org

# =============================================================================
# ADMIN USER CONFIGURATION
# =============================================================================

# Django superuser (for automated creation)
DJANGO_SUPERUSER_EMAIL=admin@pyladiesseoul.org
DJANGO_SUPERUSER_PASSWORD=secure_admin_password_change_me

# =============================================================================
# DEPLOYMENT CONFIGURATION
# =============================================================================

# Data directory for volumes
DATA_DIR=./data

# Backup retention
BACKUP_RETENTION_DAYS=7

# Build information (set by CI/CD)
BUILD_DATE=
GIT_COMMIT=

# =============================================================================
# MONITORING AND APM
# =============================================================================

# Elastic APM (optional)
ELASTIC_APM_SECRET_TOKEN=your-elastic-apm-token

# =============================================================================
# SOCIAL AUTHENTICATION (if implemented)
# =============================================================================

# Google OAuth2 (optional)
GOOGLE_OAUTH2_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH2_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth2 (optional)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# =============================================================================
# API KEYS AND EXTERNAL SERVICES
# =============================================================================

# reCAPTCHA (if using)
RECAPTCHA_PUBLIC_KEY=your-recaptcha-public-key
RECAPTCHA_PRIVATE_KEY=your-recaptcha-private-key

# Analytics (optional)
GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX

# =============================================================================
# DEVELOPMENT ONLY SETTINGS
# =============================================================================

# These settings should only be used in development
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# DATABASE_URL=sqlite:///db.sqlite3